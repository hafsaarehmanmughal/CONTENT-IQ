// ContentIQ - Prisma Schema
// Entities: User, ContentUpload, ServiceSelection, Report, SystemLog
// Database: SQLite (free, no setup needed)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              Int               @id @default(autoincrement())
  fullName        String
  email           String            @unique
  password        String
  role            String            @default("user")   // "user" | "admin"
  plan            String            @default("free")   // "free" | "pro"
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  contentUploads  ContentUpload[]
  systemLogs      SystemLog[]
}

model ContentUpload {
  id              Int               @id @default(autoincrement())
  userId          Int
  mode            String            // "text" | "file"
  originalText    String?
  fileName        String?
  fileSize        Int?
  createdAt       DateTime          @default(now())

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  report          Report?
}

model Report {
  id              Int               @id @default(autoincrement())
  uploadId        Int               @unique
  userId          Int
  services        String            // JSON array stored as string e.g. '["seo","ai_detection"]'
  status          String            @default("processing") // "processing" | "completed" | "failed"
  results         String?           // JSON results stored as string
  createdAt       DateTime          @default(now())
  completedAt     DateTime?

  upload          ContentUpload     @relation(fields: [uploadId], references: [id], onDelete: Cascade)
}

model SystemLog {
  id              Int               @id @default(autoincrement())
  userId          Int?
  action          String            // e.g. "login", "upload", "analyze", "error"
  detail          String?
  createdAt       DateTime          @default(now())

  user            User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
}
